# ═══════════════════════════════════════════════════════════
#  AI Web Auditor & Sales Engine 2026 — Environment Config
# ═══════════════════════════════════════════════════════════

# ── AI (Required) ─────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash          # or gemini-1.5-pro for deeper analysis

# ── Google PageSpeed Insights (Optional, 25 req/day free) ─
GOOGLE_PAGESPEED_API_KEY=your_pagespeed_key_here

# ── Database ──────────────────────────────────────────────
# SQLite (dev / local Windows):
DATABASE_URL=sqlite+aiosqlite:///./webauditor.db
# PostgreSQL (prod):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/webauditor

# ── Redis (for Celery task queue) ─────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App Settings ──────────────────────────────────────────
APP_SECRET_KEY=change_me_to_a_random_secret_string
MAX_CONCURRENT_AUDITS=3          # Max parallel Playwright browsers
AUDIT_TIMEOUT_SECONDS=120        # Timeout per audit
RATE_LIMIT_GEMINI_RPM=55         # Requests per minute to Gemini (stay under 60)

# ── Report Settings ───────────────────────────────────────
REPORT_BRAND_NAME=AI Web Auditor
REPORT_BRAND_COLOR=#6366f1        # Indigo — change to your brand color
REPORTS_DIR=./reports             # Where to save generated reports

# ── Email (Optional — for report delivery) ────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
